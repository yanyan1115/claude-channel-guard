# Claude Channel Guard runtime paths.
CHANNEL_GUARD_DIR="$HOME/.claude/channel-guard"

# Telegram guarded MCP wrapper.
# Point this at your installed official Claude Code Telegram plugin directory.
TELEGRAM_GUARD_UPSTREAM_DIR="$HOME/.claude/plugins/cache/claude-plugins-official/telegram/<version>"

# Optional but recommended. Compute with:
# sha256sum "$TELEGRAM_GUARD_UPSTREAM_DIR/server.ts"
TELEGRAM_GUARD_UPSTREAM_SERVER_SHA256="<sha256-of-official-telegram-server.ts>"

# Optional burst tuning for pure chat.
CHANNEL_GUARD_BURST_SECONDS=30
CHANNEL_GUARD_MAX_OUTBOUND=8
CHANNEL_GUARD_MAX_CHARS=6000
CHANNEL_GUARD_GRANT_START_TTL=600
